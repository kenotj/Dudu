{
  "name": "dudu",
  "version": "0.1.0",
  "description": "Open-source bilingual translation extension with box-fit UI translation",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.ts'"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "pdfjs-dist": "^4.3.136",
    "preact": "^10.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@preact/preset-vite": "^2.8.2",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "eslint": "^8.57.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vitest": "^1.6.0"
  }
}
